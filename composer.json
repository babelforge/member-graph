{
    "name": "babelforge/member-graph",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "BabelForge\\MemberGraph\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "BabelForge\\MemberGraph\\Tests\\": "tests/"
        }
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/babelforge/php-source-registry.git"
        }
    ],
    "require": {
        "php": ">=8.4",
        "babelforge/php-source-registry": "dev-main",
        "nikic/php-parser": "^5.7",
        "phpstan/phpdoc-parser": "^2.3",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.5",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.95"
    },
    "scripts": {
        "cs": "php-cs-fixer fix --dry-run --diff",
        "cs-fix": "php-cs-fixer fix",
        "test": "phpunit",
        "analyse": "phpstan analyse",
        "qa": [
            "@cs",
            "@analyse",
            "@test"
        ]
    }
}
